          <mxGeometry x="480" y="804" width="220" height="58" as="geometry" />
        </mxCell>

        <!-- ACTORS -->
        <!-- Admin (left) center y ≈ midpoint all UCs = (131+833)/2 = 482 → y=452 -->
        <mxCell id="act-admin" parent="1" vertex="1"
          style="shape=actor;whiteSpace=wrap;html=1;fontSize=15;fontStyle=1;
                 fontFamily=Sarabun;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DSarabun;
                 verticalLabelPosition=bottom;verticalAlign=top;fillColor=#f8cecc;strokeColor=#b85450;"
          value="Admin">
          <mxGeometry x="70" y="452" width="40" height="60" as="geometry" />
        </mxCell>

        <!-- KOCH User (right) center y ≈ mid of UC1,2,6,7,9,10 = (131+833)/2=482 → y=452 -->
        <mxCell id="act-user" parent="1" vertex="1"
          style="shape=actor;whiteSpace=wrap;html=1;fontSize=15;fontStyle=1;
                 fontFamily=Sarabun;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DSarabun;
                 verticalLabelPosition=bottom;verticalAlign=top;fillColor=#f8cecc;strokeColor=#b85450;"
          value="KOCH User">
          <mxGeometry x="970" y="452" width="40" height="60" as="geometry" />
        </mxCell>

        <!-- === ASSOCIATIONS ===
             Admin → UC1,2,3,4,5,7,8,10
             KOCH User → UC1,2,6,7,9,10
        -->

        <!-- Admin → UCs (exit right, entry left) -->
        <mxCell id="e-a1" edge="1" parent="1" source="act-admin" target="uc1"
          style="endArrow=none;edgeStyle=none;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#b85450;">
          <mxGeometry relative="1" as="geometry" />
