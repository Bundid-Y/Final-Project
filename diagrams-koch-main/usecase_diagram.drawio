<mxfile host="app.diagrams.net" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36" version="29.6.6">
  <diagram name="KOCH Use Case Diagram" id="koch-usecase">
    <mxGraphModel dx="1422" dy="762" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!--
          10 UCs × 58px + 9 gaps × 20px = 742px content
          System box: x=200, y=30, w=780, h=820
          Title ~45px → UC start y = 30+45+27 = 102
          UCn y = 102 + (n-1)*78
          UC center-x = 200+390 = 590  →  x = 590-110 = 480
          Actor Admin: x=70,  y=405 (center at ~435)
          Actor KOCH User: x=970, y=405 (center at ~435)
        -->

        <!-- SYSTEM BOUNDARY -->
        <mxCell id="sys-box" parent="1" vertex="1"
          style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fontSize=15;fontStyle=1;
                 fontFamily=Sarabun;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DSarabun;
                 fillColor=none;strokeColor=#000000;"
          value="ระบบจัดการ KOCH (KOCH Management System)">
          <mxGeometry x="200" y="30" width="780" height="820" as="geometry" />
        </mxCell>

        <!-- USE CASES — all 220×58, gap=20, start y=102 -->

        <!-- UC1: เข้าสู่ระบบ  y=102 -->
        <mxCell id="uc1" parent="1" vertex="1"
          style="ellipse;whiteSpace=wrap;html=1;fontSize=14;fontFamily=Sarabun;
                 fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DSarabun;
                 fillColor=#ffffff;strokeColor=#b85450;"
          value="เข้าสู่ระบบ">
          <mxGeometry x="480" y="102" width="220" height="58" as="geometry" />
        </mxCell>

        <!-- UC2: หน้าหลัก  y=180 -->
        <mxCell id="uc2" parent="1" vertex="1"
          style="ellipse;whiteSpace=wrap;html=1;fontSize=14;fontFamily=Sarabun;
                 fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DSarabun;
                 fillColor=#ffffff;strokeColor=#b85450;"
          value="หน้าหลัก KOCH">
          <mxGeometry x="480" y="180" width="220" height="58" as="geometry" />
        </mxCell>

        <!-- UC3: จัดการผู้ใช้งาน  y=258 -->
        <mxCell id="uc3" parent="1" vertex="1"
          style="ellipse;whiteSpace=wrap;html=1;fontSize=14;fontFamily=Sarabun;
                 fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DSarabun;
                 fillColor=#ffffff;strokeColor=#b85450;"
          value="จัดการผู้ใช้งาน">
          <mxGeometry x="480" y="258" width="220" height="58" as="geometry" />
        </mxCell>

        <!-- UC4: จัดการเนื้อหา  y=336 -->
        <mxCell id="uc4" parent="1" vertex="1"
