<mxfile host="draw.io">
  <diagram name="Physical ER Diagram - KOCH System" id="koch_er_v2">
    <mxGraphModel dx="3200" dy="3200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="4000" pageHeight="3000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!--
          LAYOUT (5 columns × 3 rows, 340px col gap, 100px row gap)
          Col:  A=40  B=420  C=800  D=1180  E=1560
          Row:  R1=40  R2=700  R3=1400

          TABLES:
          R1: sliders(A), partners(B), companies(C), featured_products(D), contact_messages(E)
          R2: products(A), koch_quotations(B), users(C), system_settings(D), truck_types(E)
          R3: notifications(A), activity_logs(B), user_sessions(C), user_permissions(D), password_resets(E)

          FK RELATIONSHIPS (all 1:N from parent):
          companies(1) → users(N)           rel_1   C.R1 → C.R2  vertical down
          companies(1) → koch_quotations(N) rel_2   C.R1 → B.R2  diagonal
          companies(1) → sliders(N)         rel_3   C.R1 → A.R1  horizontal left
          companies(1) → partners(N)        rel_4   C.R1 → B.R1  horizontal left
          companies(1) → featured_products(N) rel_5 C.R1 → D.R1  horizontal right
          companies(1) → contact_messages(N)  rel_6 C.R1 → E.R1  horizontal right
          companies(1) → system_settings(N)   rel_7 C.R1 → D.R2  diagonal
          companies(1) → truck_types(N)       rel_8 C.R1 → E.R2  diagonal
          companies(1) → notifications(N)     rel_9 C.R1 → A.R3  far diagonal
          companies(1) → activity_logs(N)     rel_10 C.R1 → B.R3 far diagonal
          companies(1) → password_resets(N)   rel_11 C.R1 → E.R3 far diagonal
          users(1) → koch_quotations.user_id(N)  rel_12 C.R2 → B.R2
          users(1) → koch_quotations.quoted_by(N) rel_13 C.R2 → B.R2
          users(1) → notifications(N)       rel_14 C.R2 → A.R3
          users(1) → activity_logs(N)       rel_15 C.R2 → B.R3
          users(1) → user_sessions(N)       rel_16 C.R2 → C.R3
          users(1) → user_permissions(N)    rel_17 C.R2 → D.R3
          products(1) → koch_quotations.product_id(N) rel_18 A.R2 → B.R2
        -->

        <!-- ========== ROW 1 ========== -->

