                 fillColor=#ffffff;strokeColor=#000000;"
          value="หน้าหลัก">
          <mxGeometry x="450" y="180" width="220" height="58" as="geometry" />
        </mxCell>

        <!-- UC3: จัดการข้อมูลผู้ใช้งาน  y=258 -->
